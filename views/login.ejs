
<!DOCTYPE html>
<html>
<head>
  <title><%= pageTitle %></title>
</head>
<body>

  <h1>Login</h1>

  <form action="/login" method="POST">
    
    <input 
      type="email" 
      name="email" 
      placeholder="Enter Email" 
      required
    >

    <input 
      type="password" 
      name="password" 
      placeholder="Enter Password" 
      required
    >

    <button type="submit">Login</button>

  </form>

</body>
</html>