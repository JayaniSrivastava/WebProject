<!DOCTYPE html>
<html>
<head>
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/addHome.css">
</head>
<body>

  <div class="container">
    <h1>Add a New Home</h1>

    <form action="/add-home" method="POST" class="form-card">

      <div class="form-control">
        <label>House Name</label>
        <input type="text" name="houseName" placeholder="Enter house name" required>
      </div>

      <div class="form-control">
        <label>City</label>
        <input type="text" name="city" placeholder="Enter city" required>
      </div>

      <div class="form-control">
        <label>House Number</label>
        <input type="text" name="houseNo" placeholder="Enter house number" required>
      </div>

      <div class="form-control">
        <label>Address</label>
        <input type="text" name="address" placeholder="Enter full address" required>
      </div>

      <div class="form-control">
        <label>Image URL</label>
        <!-- ✅ FIXED HERE -->
        <input type="text" name="image" placeholder="Paste image link" required>
      </div>

      <div class="form-control">
        <label>Price</label>
        <input type="number" name="price" placeholder="Enter price" required>
      </div>

      <button type="submit" class="btn">Add Home</button>
    </form>

    <a href="/" class="back-link">⬅ Back to Home</a>
  </div>

</body>
</html>