<!DOCTYPE html>
<html>
<head>
  <title>Edit Home</title>
  <link rel="stylesheet" href="/editHome.css">
</head>

<body>

<header>
  <nav>
    <div class="logo">Airbnb Clone</div>
    <div class="nav-links">
  <a href="/">Home</a>
  <a href="/favourites">Favourites</a>
  <a href="/booked">Booked</a>

  <% if (locals.user) { %>
    <a href="/add-home">Add Home</a>

    <form action="/logout" method="POST" style="display:inline;">
      <button type="submit">Logout</button>
    </form>
  <% } else { %>
    <a href="/login">Login</a>
    <a href="/signup">Signup</a>
  <% } %>
</div>
  </nav>
</header>

<div class="container">

  <h1>Edit Home</h1>

  <form action="/edit-home" method="POST" class="form-card">

    <input type="hidden" name="homeId" value="<%= home._id %>">

    <div class="form-control">
      <label>House Name</label>
      <input type="text" name="houseName" value="<%= home.houseName %>" required>
    </div>

    <div class="form-control">
      <label>House Number</label>
      <input type="text" name="houseNo" value="<%= home.houseNo %>" required>
    </div>

    <div class="form-control">
      <label>Address</label>
      <input type="text" name="address" value="<%= home.address %>" required>
    </div>

    <!-- 🔥 IMPORTANT FIX -->
    <div class="form-control">
      <label>Image URL</label>
      <input type="text" name="image" value="<%= home.image %>" required>
    </div>

    <div class="form-control">
      <label>Price</label>
      <input type="number" name="price" value="<%= home.price %>" required>
    </div>

    <button type="submit" class="btn">Update Home</button>

  </form>

  <a href="/" class="back-link">⬅ Back to Home</a>

</div>

</body>
</html>